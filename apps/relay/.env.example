# ─── Relay Server Configuration ───────────────────────────
# Hostname used in SMTP banner and EHLO
RELAY_HOSTNAME=relay.pixora.com

# SMTP port (25 for production, use 2525 for non-admin local dev)
SMTP_PORT=25

# Health check HTTP port
HEALTH_PORT=3001

# ─── Database (Neon Postgres) ─────────────────────────────
# Same connection string used by the Next.js app
# Get from: https://console.neon.tech → your project → Connection Details
DATABASE_URL=

# ─── TLS (optional for dev, required for production) ──────
# Paths to Let's Encrypt certificates on the VPS
# Leave empty for local development (runs without TLS)
TLS_KEY_PATH=
TLS_CERT_PATH=

# ─── Environment ─────────────────────────────────────────
NODE_ENV=development
